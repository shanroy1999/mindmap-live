# ─────────────────────────────────────────────────────────────────────────────
# MindMap Live — docker-compose environment variables
#
# Copy this file to .env before running `docker compose up`:
#   cp .env.example .env
#
# .env is git-ignored — never commit real credentials.
# This file (.env.example) IS checked in and documents all required variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────

POSTGRES_USER=mindmap
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mindmap_db

# ── How to wire these into backend/.env ───────────────────────────────────────
#
# When the FastAPI backend runs on the HOST (typical for local dev):
#
#   DATABASE_URL=postgresql+asyncpg://mindmap:changeme@localhost:5432/mindmap_db
#   REDIS_URL=redis://localhost:6379
#
# When the backend also runs inside Docker (e.g. a future backend service),
# replace `localhost` with the Compose service names:
#
#   DATABASE_URL=postgresql+asyncpg://mindmap:changeme@postgres:5432/mindmap_db
#   REDIS_URL=redis://redis:6379
#
# Adminer login (http://localhost:8080):
#   System   → PostgreSQL
#   Server   → postgres      (pre-filled by ADMINER_DEFAULT_SERVER)
#   Username → mindmap       (POSTGRES_USER)
#   Password → changeme      (POSTGRES_PASSWORD)
#   Database → mindmap_db    (POSTGRES_DB)
