# ─────────────────────────────────────────────────────────────────────────────
# MindMap Live — backend environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Must use the postgresql+asyncpg:// scheme for the async SQLAlchemy driver.
# A plain postgresql:// URL is also accepted and will be auto-upgraded.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mindmap_live

# Set to "true" to echo all generated SQL to stdout (useful during development).
SQL_ECHO=false

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET=replace-with-a-strong-random-secret

# Standard JWT signing algorithm. HS256 is recommended for single-service use.
JWT_ALGORITHM=HS256

# Access token lifetime in minutes. Keep short; use refresh tokens for longevity.
JWT_EXPIRY_MINUTES=60

# ── AI ────────────────────────────────────────────────────────────────────────
# Anthropic API key — obtain from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for WebSocket pub/sub across multiple backend processes.
REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example for production: https://app.example.com,https://www.example.com
FRONTEND_ORIGIN=http://localhost:5173
